{
  "manifest_version": 3,
  "name": "PNG Export for Claude Design",
  "version": "1.8.0",
  "minimum_chrome_version": "125",
  "description": "Export Claude Design artifacts as PNG or PDF at original size",
  "permissions": ["downloads", "tabs", "debugger", "offscreen", "storage"],
  "host_permissions": [
    "*://claude.ai/*",
    "*://claudeusercontent.com/*",
    "*://*.claudeusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/design/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claudeusercontent.com/*",
        "https://*.claudeusercontent.com/*"
      ],
      "js": ["frame-capture.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_idle"
    }
  ]
}
